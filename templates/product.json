{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "measurements": {
          "type": "futalerie_measurements"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "shipping-info": {
          "type": "custom_liquid",
          "settings": {
            "liquid": "<div class=\"futalerie-product-shipping\"><div>📦 <strong>Expédition sous 24h</strong></div><div>🚚 <strong>Livraison suivie</strong> 3-5 jours</div><div>Frais de port : 4,90€ (Gratuit dès 80€)</div></div>"
          }
        },
        "description": {
          "type": "description"
        },
        "entretien": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Entretien",
            "icon": "heart",
            "content": "<p>Pour préserver vos pièces :</p><ul><li>Lavage en machine à 30°C maximum</li><li>Lavage à l'envers pour préserver la couleur</li><li>Pas de sèche-linge (rétrécissement)</li><li>Repassage à basse température si nécessaire</li></ul>",
            "page": ""
          }
        },
        "livraison-retours": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Livraison & Retours",
            "icon": "truck",
            "content": "<p><strong>Livraison :</strong> Expédition sous 24h. Livraison en 2-4 jours ouvrés. Frais : 4,90€ (gratuit dès 80€).</p><p><strong>Retours :</strong> 14 jours pour retourner si l'article ne vous convient pas. Contactez-nous avant tout retour à contact@lafutalerie.com — réponse sous 24h.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Partager"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "measurements",
        "variant_picker",
        "buy_buttons",
        "shipping-info",
        "description",
        "entretien",
        "livraison-retours",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "show",
        "hide_variants": false,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "D'autres pièces qui pourraient vous plaire",
        "heading_size": "h2",
        "columns_desktop": 4,
        "color_scheme": "scheme-2",
        "image_ratio": "adapt",
        "show_secondary_image": true,
        "show_vendor": true,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    }
  },
  "order": [
    "main",
    "related-products"
  ]
}
