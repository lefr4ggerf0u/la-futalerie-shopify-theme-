{% comment %}
  La Futalerie - Hero Section
  Split layout: text left, image right (inspired by DXL)
{% endcomment %}

<section class="futalerie-hero">
  <div class="futalerie-hero__left">
    {%- if section.settings.eyebrow != blank -%}
      <span class="futalerie-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h1 class="futalerie-hero__title">{{ section.settings.title | escape }}</h1>

    {%- if section.settings.tagline != blank -%}
      <p class="futalerie-hero__tagline">{{ section.settings.tagline | escape }}</p>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="futalerie-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}

    <div class="futalerie-hero__ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url }}" class="btn-futalerie-primary">
          {{ section.settings.cta_primary_label | escape }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url }}" class="btn-futalerie-secondary">
          {{ section.settings.cta_secondary_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <div class="futalerie-hero__trust">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_item' -%}
          <div class="futalerie-hero__trust-item" {{ block.shopify_attributes }}>
            <span class="icon">{{ block.settings.icon }}</span>
            <span>{{ block.settings.text | escape }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="futalerie-hero__right">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          class: 'futalerie-hero__image',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '375, 550, 750, 1100',
          sizes: '50vw'
      }}
    {%- elsif section.settings.image_url != blank -%}
      <div class="futalerie-hero__image futalerie-hero__image--bg" style="background-image: url('{{ section.settings.image_url }}');"></div>
    {%- else -%}
      <div class="futalerie-hero__image" style="background: linear-gradient(135deg, #2B2B2B 0%, #4A5568 100%);"></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero La Futalerie",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "URL image (si pas d'image sélectionnée)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texte au-dessus du titre",
      "default": "Levi's · Carhartt · Dickies · Wrangler · Lee"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "Enfin des jeans à ta taille."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline (sous le titre)",
      "default": "Grâce à la seconde main."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Levi's, Carhartt, Dickies vérifiés et mesurés. Mesures précises, contrôle qualité, retour gratuit — zéro mauvaise surprise."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Bouton principal - Texte",
      "default": "Voir la collection"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Bouton principal - Lien"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Bouton secondaire - Texte",
      "default": "Comment ça marche ?"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Bouton secondaire - Lien"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Badge de confiance",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icône (emoji)",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison suivie"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero La Futalerie",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "⭐",
            "text": "4.9/5 sur 127 avis"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "✓",
            "text": "Livraison 24h"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "✓",
            "text": "Retours faciles"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "✓",
            "text": "Paiement sécurisé"
          }
        }
      ]
    }
  ]
}
{% endschema %}
