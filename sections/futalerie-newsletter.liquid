{% comment %}
  La Futalerie - Newsletter signup
{% endcomment %}

<section class="futalerie-newsletter">
  <div class="futalerie-container">
    {%- if section.settings.title != blank -%}
      <h2 class="futalerie-newsletter__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="futalerie-newsletter__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'futalerie-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="futalerie-newsletter__form">
        <input
          type="email"
          name="contact[email]"
          id="futalerie-newsletter-email"
          class="futalerie-newsletter__input"
          placeholder="{{ section.settings.placeholder | default: 'Votre adresse email' | escape }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="futalerie-newsletter__submit">
          {{ section.settings.button_label | default: 'S\'inscrire' | escape }}
        </button>
      </div>

      {%- if form.posted_successfully? -%}
        <p style="color: #86efac; margin-top: 1rem; font-size: 0.95rem;">
          ✓ Merci ! Vous recevrez nos meilleures pièces en avant-première.
        </p>
      {%- endif -%}

      {%- if form.errors -%}
        <p style="color: #fca5a5; margin-top: 1rem; font-size: 0.9rem;">
          {{ form.errors | default_errors }}
        </p>
      {%- endif -%}
    {%- endform -%}

    {%- if section.settings.note != blank -%}
      <p class="futalerie-newsletter__note">{{ section.settings.note | escape }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Les meilleures pièces en avant-première"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Soyez alerté des nouvelles trouvailles. Pas de spam, que des belles pièces."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder email",
      "default": "Votre adresse email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "S'inscrire"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note sous le formulaire",
      "default": "Pas de spam. Désinscription en 1 clic."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
