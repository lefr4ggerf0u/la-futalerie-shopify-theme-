{% comment %}
  La Futalerie - Page FAQ
{% endcomment %}

<div class="futalerie-faq">
  <h1>{{ section.settings.title | escape }}</h1>
  {%- if section.settings.intro != blank -%}
    <p class="futalerie-faq__intro">{{ section.settings.intro | escape }}</p>
  {%- endif -%}

  {%- assign current_group = '' -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'group' -%}
      {%- if current_group != '' -%}
        </div>
      {%- endif -%}
      <div class="futalerie-faq__group">
        <h2 class="futalerie-faq__group-title">{{ block.settings.title | escape }}</h2>
      {%- assign current_group = block.settings.title -%}
    {%- elsif block.type == 'qa' -%}
      <details class="futalerie-faq__item" {{ block.shopify_attributes }}>
        <summary class="futalerie-faq__question">{{ block.settings.question | escape }}</summary>
        <div class="futalerie-faq__answer">{{ block.settings.answer }}</div>
      </details>
    {%- endif -%}
  {%- endfor -%}
  {%- if current_group != '' -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Questions fréquentes"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Introduction",
      "default": "Tout ce que vous avez besoin de savoir avant d'acheter."
    }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Catégorie",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre de la catégorie",
          "default": "Achat & commande"
        }
      ]
    },
    {
      "type": "qa",
      "name": "Question / Réponse",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Comment passer commande ?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Réponse",
          "default": "<p>Parcourez la collection, choisissez votre pièce, ajoutez-la au panier et suivez les étapes de paiement. Pas besoin de créer un compte.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "group", "settings": { "title": "Achat & commande" } },
        { "type": "qa", "settings": {
          "question": "Comment passer commande ?",
          "answer": "<p>Parcourez la collection, choisissez votre pièce, ajoutez-la au panier et suivez les étapes de paiement. Pas besoin de créer un compte.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Quels modes de paiement acceptez-vous ?",
          "answer": "<p>Nous acceptons les cartes bancaires (Visa, Mastercard), PayPal et Apple Pay. Le paiement est 100% sécurisé.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Puis-je réserver un article ?",
          "answer": "<p>Non, les articles ne peuvent pas être réservés. Chaque pièce est unique — si elle vous intéresse, n'attendez pas trop !</p>"
        }},
        { "type": "group", "settings": { "title": "Produits" } },
        { "type": "qa", "settings": {
          "question": "Comment connaître ma taille ?",
          "answer": "<p>Chaque fiche produit indique les mesures exactes au centimètre : tour de taille, longueur totale, entrejambe, largeur cuisse et ouverture bas. Comparez avec un pantalon qui vous va bien.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Que signifient les états (Excellent, Très bon, Bon) ?",
          "answer": "<p><strong>Excellent :</strong> Pièce comme neuve ou quasi-neuve, aucun défaut visible.<br><strong>Très bon :</strong> Légères marques d'usure normales, aucun défaut notable.<br><strong>Bon :</strong> Usure visible mais pièce en parfait état de port. Les défauts sont toujours mentionnés explicitement.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Les produits sont-ils authentiques ?",
          "answer": "<p>Oui, à 100%. Nous ne vendons que des pièces de marques vérifiées (Levi's, Carhartt, Dickies, Wrangler, Lee) avec les étiquettes photographiées. Chaque pièce est inspectée avant mise en vente.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "D'où viennent les pièces ?",
          "answer": "<p>Nos pièces sont chinées auprès de particuliers, en dépôt-vente et dans des ventes de stocks. Chaque article est sélectionné personnellement et inspecté avant d'être mis en vente.</p>"
        }},
        { "type": "group", "settings": { "title": "Livraison" } },
        { "type": "qa", "settings": {
          "question": "Quels sont les délais de livraison ?",
          "answer": "<p>Expédition sous 24h (jours ouvrés). Livraison en 2-4 jours ouvrés par Colissimo ou équivalent avec numéro de suivi.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Quels sont les frais de livraison ?",
          "answer": "<p>4,90€ pour toute commande. Livraison offerte à partir de 80€ d'achat.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Livrez-vous en dehors de la France ?",
          "answer": "<p>Actuellement nous livrons en France métropolitaine uniquement. Pour d'autres destinations, contactez-nous.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Puis-je suivre mon colis ?",
          "answer": "<p>Oui, vous recevrez un email avec votre numéro de suivi dès l'expédition.</p>"
        }},
        { "type": "group", "settings": { "title": "Retours & échanges" } },
        { "type": "qa", "settings": {
          "question": "Quelle est votre politique de retour ?",
          "answer": "<p>Vous avez 14 jours à compter de la réception pour retourner un article s'il ne vous convient pas. La pièce doit être dans l'état reçu, non portée. Contactez-nous avant tout retour.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Les frais de retour sont-ils à ma charge ?",
          "answer": "<p>Oui, les frais de retour sont à votre charge sauf en cas d'erreur de notre part ou de produit non conforme à la description.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Puis-je échanger un article ?",
          "answer": "<p>Comme chaque pièce est unique, un échange direct n'est pas possible. Vous pouvez retourner l'article et en commander un autre.</p>"
        }},
        { "type": "group", "settings": { "title": "Contact" } },
        { "type": "qa", "settings": {
          "question": "Comment vous contacter ?",
          "answer": "<p>Par email : contact@lafutalerie.com — ou via le <a href=\"/pages/contact\">formulaire de contact</a>.</p>"
        }},
        { "type": "qa", "settings": {
          "question": "Quel est le délai de réponse ?",
          "answer": "<p>Nous répondons sous 24h en jours ouvrés, généralement bien plus vite !</p>"
        }}
      ]
    }
  ]
}
{% endschema %}
